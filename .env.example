# Public snapshot: copy to `.env.local` for local dev. Do not commit real values.
# Site content is still loaded from your deployed read-only Site UI HTTP API (GET /site-ui).

NEXT_PUBLIC_AWS_REGION=us-east-1

# HTTP API base URL (no trailing slash). Must allow anonymous GET /site-ui.
# Example (replace with your real API, do not commit secrets here):
# NEXT_PUBLIC_SITE_UI_API_URL=https://YOUR_API_ID.execute-api.YOUR_AWS_REGION.amazonaws.com
NEXT_PUBLIC_SITE_UI_API_URL=
