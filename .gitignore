# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# AWS CLI temp files (scripts may create these under scripts/ or cwd)
_sse-run.json
**/_*-run.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Lambda bundle + CloudFormation package output
/lambda/site-ui/node_modules
/lambda/site-ui/dist
/infrastructure/packaged-site-ui-api.yaml
